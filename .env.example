# Copy to .env and fill in values. Never commit .env.
# See docs/data_retrieval_protocol.md (PostgreSQL, RLS) and
# docs/security_and_legal_compliance.md (secrets handling).

# Published host port for the docker-compose `db` service (avoids clashing with local Postgres on 5432).
POSTGRES_PUBLISH_PORT=5433

# App runtime: use ``tunde_app`` so Row-Level Security applies (not the DB superuser).
# Host port must match POSTGRES_PUBLISH_PORT when DB runs in Docker.
DATABASE_URL=postgresql://tunde_app:tunde_app_dev@localhost:5433/tunde

# Alembic / migrations: DB owner (superuser in local docker-compose Postgres image).
ALEMBIC_DATABASE_URL=postgresql://tunde:tunde@localhost:5433/tunde

# Optional: human approval / CAPTCHA notifications (human_approval_gate.md)
TELEGRAM_TOKEN=

# Application-managed encryption for sensitive columns (generate a strong secret; store outside repo)
ENCRYPTION_KEY=

# LLM (Gemini and/or DeepSeek only — no OpenAI)
DEFAULT_LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
