# Copy to .env and fill in values. Never commit .env.
# See docs/data_retrieval_protocol.md (PostgreSQL, RLS) and
# docs/security_and_legal_compliance.md (secrets handling).

# Published host port for the docker-compose `db` service (avoids clashing with local Postgres on 5432).
POSTGRES_PUBLISH_PORT=5433

# App runtime: SQLAlchemy URL read from the environment (never hardcoded in application code).
# PostgreSQL (default): use ``tunde_app`` so Row-Level Security applies (not the DB superuser).
# Host port must match POSTGRES_PUBLISH_PORT when DB runs in Docker.
DATABASE_URL=postgresql://tunde_app:tunde_app_dev@localhost:5433/tunde
# MySQL/MariaDB in Docker: bare ``mysql://`` is rewritten to ``mysql+pymysql://`` (pure Python driver).
# Example: DATABASE_URL=mysql://tunde_app:secret@db:3306/tunde

# Alembic / migrations: DB owner (superuser in local docker-compose Postgres image).
ALEMBIC_DATABASE_URL=postgresql://tunde:tunde@localhost:5433/tunde

# Optional: human approval / CAPTCHA notifications (human_approval_gate.md)
TELEGRAM_TOKEN=
# Your user or group chat id (numeric string from @userinfobot or getUpdates)
MY_TELEGRAM_CHAT_ID=

# Application-managed encryption for sensitive columns (generate a strong secret; store outside repo)
ENCRYPTION_KEY=

# LLM: Gemini (reasoning/multimodal) and/or DeepSeek (cost-efficient chat)
DEFAULT_LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Native image generation (Telegram “draw / generate an image…”). See Google AI image-generation docs.
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- Research missions (POST /mission/start) ---
# Plain-language guide: docs/research_language_and_search_locales.md
# Technical snapshot: docs/current_implementation.md
#
# Default final report language when the request body omits output_language. Use en or ar.
TUNDE_RESEARCH_OUTPUT_LANG=en
#
# Optional: comma-separated hl:gl pairs so web search favors those languages/regions (e.g. de:DE,fr:FR).
# First 3 valid pairs used; need at least 2 valid pairs or this is ignored. See the guide above.
# Example: en:GB,de:DE,fr:FR
TUNDE_RESEARCH_SEARCH_LOCALES=

# Origin of this API for Telegram report links (scheme + host + port only; no path; no trailing slash).
# Alias: REPORT_PUBLIC_BASE_URL (same meaning as TUNDE_PUBLIC_BASE_URL).
# If unset, missions default to http://localhost:8000 (fine on the same machine; phones cannot open it).
# In production set your public HTTPS origin, e.g. https://tunde.example.com
TUNDE_PUBLIC_BASE_URL=http://localhost:8000

# --- Optional: “Send to Email” post-report action (SMTP) ---
# Default From is reports@tundeai.com; your provider must allow sending as that address (or override).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
REPORT_FROM_EMAIL=reports@tundeai.com
# Recipient for the Telegram “Send to Email” button (your inbox).
REPORT_EMAIL_TO=

# --- Optional: programmatic web search (fail-safe rotation, browser SERP is fallback) ---
# Configure one or more backends. Order: Google Custom Search → Serper → Riley-compatible POST API.
# Approx. free tiers (verify with each vendor): Google CSE ~100 queries/day; Serper higher; Riley depends on plan.
#
# Google Programmable Search (Custom Search JSON API)
GOOGLE_SEARCH_API_KEY=
# Search engine ID (cx) from https://programmablesearchengine.google.com/
GOOGLE_CUSTOM_SEARCH_CX=
#
# Serper.dev — https://serper.dev
SERPER_API_KEY=
#
# Riley / custom JSON search API — set POST endpoint and key (Bearer first, then X-API-KEY on 401)
RILEY_API_KEY=
RILEY_SEARCH_API_URL=
#
# Set to 1/true to stop printing rotation lines to stdout (file logging to logs/api_errors.txt remains)
# TUNDE_SEARCH_API_SILENT_STDOUT=
